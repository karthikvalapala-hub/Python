param(
    [string]$ReportServerUrl,
    [string]$DataSourcePath,
    [string]$Mode = "single"  # single or all
)

Import-Module ReportingServicesTools -ErrorAction Stop

if ($Mode -eq "single") {
    $dataSource = Get-RsDataSource -Path $DataSourcePath -ReportServerUri $ReportServerUrl
    $result = @{
        Name = $dataSource.Name
        Path = $DataSourcePath
        ConnectionString = $dataSource.ConnectString
        Extension = $dataSource.Extension
    }
    $result | ConvertTo-Json -Compress
}
else {
    $dataSources = Get-RsCatalogItems -ReportServerUri $ReportServerUrl -ItemType 'DataSource'
    $results = @()
    foreach ($ds in $dataSources) {
        $details = Get-RsDataSource -Path $ds.Path -ReportServerUri $ReportServerUrl
        $results += @{
            Name = $ds.Name
            Path = $ds.Path
            ConnectionString = $details.ConnectString
            Extension = $details.Extension
        }
    }
    $results | ConvertTo-Json -Compress
}




