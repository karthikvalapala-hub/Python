import subprocess
import json
import os

def get_connection_string_using_script(report_server_url, datasource_path):
    """
    Execute an external PowerShell script file
    """
    
    script_path = os.path.join(os.path.dirname(__file__), "get_ssrs_connection.ps1")
    
    cmd = [
        "powershell",
        "-ExecutionPolicy", "Bypass",
        "-File", script_path,
        "-ReportServerUrl", report_server_url,
        "-DataSourcePath", datasource_path,
        "-Mode", "single"
    ]
    
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=30
        )
        
        if result.returncode == 0 and result.stdout.strip():
            data = json.loads(result.stdout)
            return data.get("ConnectionString")
        else:
            print(f"Error: {result.stderr}")
            return None
            
    except Exception as e:
        print(f"Exception: {e}")
        return None

